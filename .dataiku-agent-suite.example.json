{
  "defaults": {
    "profile": "codex-vanilla",
    "artifacts_dir": "./artifacts",
    "agent_timeout_seconds": 900,
    "keep": true,
    "verbose": false,
    "env": {
      "DATAIKU_URL": "${DATAIKU_URL}",
      "DATAIKU_API_KEY": "${DATAIKU_API_KEY}"
    }
  },
  "profiles": {
    "codex-vanilla": {
      "description": "Plain Codex baseline with no specialized workspace",
      "agent": "codex",
      "tags": ["codex", "vanilla"]
    },
    "dev-kit-claude": {
      "description": "Claude using a local dataiku-agent-dev-kit checkout",
      "agent": "claude",
      "agent_workspace": "/path/to/dataiku-agent-dev-kit",
      "tags": ["claude", "dev-kit"]
    },
    "dev-kit-codex": {
      "description": "Codex using a local dataiku-agent-dev-kit checkout",
      "agent": "codex",
      "agent_workspace": "/path/to/dataiku-agent-dev-kit",
      "tags": ["codex", "dev-kit"]
    },
    "repo-codex": {
      "description": "Codex using an external repo workspace",
      "agent": "codex",
      "agent_workspace": "/path/to/your-agent-repo",
      "tags": ["codex", "repo"]
    }
  }
}
